{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "dv-faq-schema-block/faq",
  "version": "1.0.0",
  "title": "FAQ Schema Accordion",
  "category": "widgets",
  "icon": "editor-help",
  "description": "A block for FAQ sections that outputs proper FAQPage schema markup.",
  "supports": {
    "html": false,
    "align": true,
    "color": {
      "text": true,
      "background": true,
      "link": true
    },
    "typography": {
      "fontSize": true,
      "lineHeight": true
    }
  },
  "attributes": {
    "displayMode": {
      "type": "string",
      "default": "accordion"
    },
    "expandIconUrl": {
      "type": "string"
    },
    "collapseIconUrl": {
      "type": "string"
    }
  },
  "textdomain": "dv-faq-schema-block",
  "editorScript": "file:./index.js",
  "editorStyle": "file:./index.css",
  "style": "file:./style-index.css"
}